          ]
        }
      ]
    },
    "api": {
      "description": "All API endpoint tests",
      "specs": ["cypress/e2e/api/**/*.cy.ts"]
    },
    "ui": {
      "description": "All UI tests",
      "specs": ["cypress/e2e/ui/**/*.cy.ts"]
    },
    "regression": {
      "description": "Full regression suite — all tests",
      "specs": ["cypress/e2e/**/*.cy.ts"]
    },
    "dev": {
      "description": "Minimal tests for framework development",
      "specs": [
        {
          "file": "cypress/e2e/ui/orders.cy.ts",
          "tests": ["should remove a product from the cart"]
        }
      ]
    }
  }
